{
  "name": "local-pocket-reader",
  "version": "2.5.0",
  "description": "Local Pocket Reader - Save articles locally and read in a clean reader view",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "web-ext": "^10.4.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "integration.test.js"
    ],
    "collectCoverageFrom": [
      "core/**/*.js",
      "!core/**/node_modules/**"
    ]
  }
}
